# 必填:你的明道账号 UUID 与 md-cloud 接入 key（v1 协作 API）
MD_ACCOUNT_ID=
MD_KEY=

# HAP 网关凭据（HAP 个人授权拿到）
# - install.py 会用 refresh_token + token 调一次 register hook，拿到 hap_key 写回 .env
# - 之后运行时只需要 MD_HAP_KEY；refresh_token / token 仅 install 时用
MD_HAP_REFRESH_TOKEN=
MD_HAP_TOKEN=
# MD_HAP_KEY=由 install.py 自动写入

# 可选:覆盖默认值。除非你跑了自己的 hook 后端,否则不用动。
# MD_HOOK_URL=https://api.mingdao.com/workflow/hooks2/xxx
# MD_HAP_REGISTER_HOOK=https://api.mingdao.com/workflow/hooks2/xxx
# MD_HAP_TOKEN_HOOK=https://api.mingdao.com/workflow/hooks2/xxx
